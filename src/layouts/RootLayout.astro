---
import "../styles/global.css";

import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MeteorShower from "../components/MeteorShower.astro";
---

<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="shortcut icon" href="icon.svg" type="image/x-icon" />
    <title>Nguyễn Thế Việt | Portfolio</title>

    <!-- Apply theme before first paint to avoid flash -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        const theme = saved === "light" ? "light" : "dark";
        document.documentElement.classList.add(theme);
      })();

      // Preserve theme across Astro View Transition page swaps.
      // astro:before-swap fires before the new document replaces the current DOM,
      // giving us a chance to copy the active theme class onto the incoming html element.
      document.addEventListener("astro:before-swap", function (event) {
        const theme = document.documentElement.classList.contains("dark")
          ? "dark"
          : "light";
        event.newDocument.documentElement.classList.remove("light", "dark");
        event.newDocument.documentElement.classList.add(theme);
      });
    </script>

    <ClientRouter />
  </head>
  <body>
    <MeteorShower />
    <Header />
    <slot />
    <Footer />
  </body>
</html>
