---
import { MoonIcon, SunIcon } from "@lucide/astro";
---

<header
  class="fixed top-0 left-0 right-0 h-14 bg-background/50 backdrop-blur-sm z-31"
>
  <div class="mx-auto max-w-4xl h-full px-6 py-2 grid grid-cols-[1fr_auto_1fr]">
    <div class="flex flex-row items-center justify-start">
      <a
        href="https://github.com/duchiru"
        target="_blank"
        class="flex flex-row items-center select-none gap-1.5"
      >
        <p
          class="text-xl font-display font-bold tracking-wider text-cyan-600 hover:text-foreground transition-colors duration-250 cursor-pointer"
        >
          duchiru
        </p>
      </a>
    </div>
    <nav class="flex flex-row items-center justify-center gap-3">
      <a
        href="/#about"
        class="font-semibold text-gray-500 hover:text-foreground transition-colors duration-250 cursor-pointer"
        >giới thiệu</a
      >

      <div class="size-1 rounded-full bg-gray-500"></div>

      <a
        href="/#projects"
        class="font-semibold text-gray-500 hover:text-foreground transition-colors duration-250 cursor-pointer"
        >dự án</a
      >

      <div class="size-1 rounded-full bg-gray-500"></div>

      <a
        href="/#conclusion"
        class="font-semibold text-gray-500 hover:text-foreground transition-colors duration-250 cursor-pointer"
        >tổng kết</a
      >
    </nav>
    <div class="flex flex-row items-center justify-end">
      <button class="rounded-lg p-2.5 bg-purple-500 cursor-pointer">
        <MoonIcon class="size-5 text-white fill-white" />
      </button>

      <button class="rounded-lg p-2.5 bg-orange-400 cursor-pointer">
        <SunIcon class="size-5 text-white fill-white" />
      </button>
    </div>
  </div>
</header>
